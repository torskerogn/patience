---
import '../styles/global.css';
import CityFull from '../components/projects/CityFull.astro';
import SheCanPlayFull from '../components/projects/SheCanPlayFull.astro';
import AabenFull from '../components/projects/AabenFull.astro';
import ProjMapFull from '../components/projects/ProjMapFull.astro';
import ThreeFull from '../components/projects/ThreeFull.astro';
import BlenderFull from '../components/projects/BlenderFull.astro';
import GameDesignFull from '../components/projects/GameDesignFull.astro';
import MotionFull from '../components/projects/MotionFull.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>verup.work /projects</title>
  </head>
<body>

  <a href="/" class="fixed top-5 left-5 text-sm cursor-pointer z-30 opacity-50 hover:opacity-100 transition-opacity">← Index</a>
  <button id="proj-prev" class="fixed left-4 top-1/2 -translate-y-1/2 text-4xl cursor-pointer z-30">&lt;</button>
  <button id="proj-next" class="fixed right-4 top-1/2 -translate-y-1/2 text-4xl cursor-pointer z-30">&gt;</button>
  <span id="project-counter" class="fixed bottom-4 left-1/2 -translate-x-1/2 text-sm opacity-50">1 / 8</span>

  <div data-project="city" class="hidden"><CityFull /></div>
  <div data-project="shecanplay" class="hidden"><SheCanPlayFull /></div>
  <div data-project="aaben" class="hidden"><AabenFull /></div>
  <div data-project="projmap" class="hidden"><ProjMapFull /></div>
  <div data-project="three" class="hidden"><ThreeFull /></div>
  <div data-project="blender" class="hidden"><BlenderFull /></div>
  <div data-project="gamedesign" class="hidden"><GameDesignFull /></div>
  <div data-project="motion" class="hidden"><MotionFull /></div>

  <script>
    import '../scripts/projects-nav.js';
  </script>

</body>
</html>