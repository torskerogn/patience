---
import '../styles/global.css';
import Splash from '../components/Splash.astro'
import ProjMap from '../components/ProjMap.astro';
import City from '../components/City.astro'
import SheCanPlay from '../components/SheCanPlay.astro';
import Three from '../components/Three.astro'
import Burger from '../components/Burger.astro';
import SlideMenu from '../components/SlideMenu.astro'
import DarkToggle from '../components/DarkToggle.astro'
import Aaben from '../components/Aaben.astro';
import SocialIcons from '../components/SocialIcons.astro';
import WhoAmi from '../components/WhoAmi.astro';
import FadeOverlay from '../components/FadeOverlay.astro';
import Blender from '../components/Blender.astro';
import GameDesign from '../components/GameDesign.astro';
import PipeDraw from '../components/PipeDraw.astro';
import Motion from '../components/Motion.astro';
import Spine from '../components/Spine.astro';
---

<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>verup.work</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono&family=VT323&family=Major+Mono+Display&family=Instrument+Serif&display=swap" rel="stylesheet">
  </head>
<body class="px-0 md:px-80">

  <div id="ui" class="opacity-0 transition-opacity duration-700">
    <Burger />
    <DarkToggle />
    <SlideMenu />
    <SocialIcons class="hidden md:grid fixed left-5 bottom-5 z-50" />
    <FadeOverlay />
    <PipeDraw />
  </div>

  <Spine />

    <script src="../scripts/menu.js"></script>
      <script>
        import '../scripts/glitch-hover.js';
      </script>
      <script>
        import '../scripts/pixel-resolve.js';
      </script>

<div id="scroll-container" class="h-[100dvh] overflow-hidden md:snap-y md:snap-proximity [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
    <section class="md:snap-start"><Splash /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><WhoAmi /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><City /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><SheCanPlay /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><Aaben /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><ProjMap /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><Three /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><Blender /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><GameDesign /></section>
    <section class="md:h-[calc(100dvh-80px)] md:snap-start md:overflow-hidden"><Motion /></section>
</div>
</body>
</html>