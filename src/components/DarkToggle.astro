---
import '../styles/global.css';
---

<div class="bg-transparent fixed left-5 top-5 z-50">
    <label class="relative inline-block w-[2.5rem] h-[1.25rem] md:w-[5rem] md:h-[2.5rem] cursor-pointer">
        <input type="checkbox" id="darkToggle" class="sr-only peer" />
        <div class="w-full h-full border-2 border-dark dark:border-light rounded-full transition-colors duration-300"></div>
        <div class="absolute top-1/2 -translate-y-1/2 left-[0.25rem] md:left-[0.375rem] w-3 h-3 md:w-7 md:h-7 bg-dark dark:bg-light rounded-full peer-checked:translate-x-5 md:peer-checked:translate-x-10 transition-all duration-300"></div>
    </label>
</div>

<script>
    import '../scripts/darkmode.js';
</script>