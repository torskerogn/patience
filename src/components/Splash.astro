---
import '../styles/global.css';
---

<div id="splash" class="h-[100dvh] snap-start grid place-items-center">
    <div class="flex flex-col items-center gap-6">
        <h1 id="intro-heading" class="text-display text-center"></h1>
        <video
            id="intro-video"
            class="w-[90vw] md:w-[70vw] aspect-video object-contain hidden rounded-2xl"
            autoplay loop muted playsinline
        >
            <source src="/videos/SHOWREEL.mp4" type="video/mp4" />
            <source src="/videos/SHOWREEL.webm" type="video/webm" />
        </video>
        
    </div>
</div>

<script>
    import '../scripts/intro.js';
</script>